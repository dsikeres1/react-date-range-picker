---
import ThemeToggle from "./ThemeToggle.astro";
import Search from "./Search.astro";
import LanguageSelector from "./LanguageSelector.astro";
import { defaultLocale, toUrlLocale } from "@/lib/i18n";

interface Props {
  lang?: string;
}

const { lang = defaultLocale } = Astro.props;

const base = import.meta.env.BASE_URL;
const langPrefix = lang === defaultLocale ? "" : `${toUrlLocale(lang)}/`;

interface NavItem {
  label: string;
  href: string;
}

const navItems: NavItem[] = [
  { label: "Tailwind v4", href: `${base}/docs/${langPrefix}tailwind4/getting-started` },
  { label: "Tailwind v3", href: `${base}/docs/${langPrefix}tailwind3/getting-started` },
  { label: "Styled", href: `${base}/docs/${langPrefix}styled/getting-started` },
  { label: "Headless", href: `${base}/docs/${langPrefix}headless/getting-started` },
  { label: "Guides", href: `${base}/docs/${langPrefix}guides/accessibility` },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-30 border-b border-border bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60"
>
  <!-- Base URL meta for client-side scripts -->
  <meta name="base-url" content={base} />

  <nav class="mx-auto flex h-14 max-w-7xl items-center gap-6 px-4">
    <!-- Mobile sidebar toggle (left, next to logo) -->
    <button
      id="mobile-menu-btn"
      type="button"
      class="-mr-4 rounded-md p-2 text-muted-foreground hover:bg-accent lg:hidden"
      aria-label="Toggle menu"
    >
      <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
      </svg>
    </button>

    <!-- Logo -->
    <a
      href={base}
      class="flex items-center gap-2 font-semibold text-foreground"
      aria-label="React Date Range Picker Home"
    >
      <img src={`${base}/logo.svg`} alt="" class="size-7" />
      <span class="hidden sm:inline">React Date Range Picker</span>
    </a>

    <!-- Nav links -->
    <div class="hidden flex-1 items-center gap-1 lg:flex">
      {
        navItems.map(({ label, href }) => {
          const isActive = currentPath.startsWith(href);
          return (
            <a
              href={href}
              class:list={[
                "rounded-md px-3 py-1.5 text-sm font-medium transition-colors",
                isActive
                  ? "bg-accent text-accent-foreground"
                  : "text-muted-foreground hover:bg-accent hover:text-accent-foreground",
              ]}
            >
              {label}
            </a>
          );
        })
      }
    </div>

    <!-- Right side -->
    <div class="ml-auto flex items-center gap-2">
      <Search />
      <LanguageSelector lang={lang} />
      <ThemeToggle />
      <a
        href="https://github.com/dsikeres1/react-date-range-picker"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-md p-2 text-muted-foreground hover:bg-accent hover:text-accent-foreground"
        aria-label="GitHub"
      >
        <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
      </a>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-border px-4 pb-4 lg:hidden">
    {
      navItems.map(({ label, href }) => {
        const isActive = currentPath.startsWith(href);
        return (
          <a
            href={href}
            class:list={[
              "block rounded-md px-3 py-2 text-sm font-medium",
              isActive
                ? "bg-accent text-accent-foreground"
                : "text-muted-foreground hover:bg-accent hover:text-accent-foreground",
            ]}
          >
            {label}
          </a>
        );
      })
    }
  </div>
</header>

<script is:inline>
  document.getElementById("mobile-menu-btn")?.addEventListener("click", () => {
    // If sidebar exists (docs pages), the sidebar script handles it
    if (document.getElementById("sidebar-mobile")) return;
    document.getElementById("mobile-menu")?.classList.toggle("hidden");
  });
</script>
