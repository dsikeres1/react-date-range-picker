---
const base = import.meta.env.BASE_URL;
---

<footer class="border-t border-footer-border bg-footer text-footer-foreground">
  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-8 px-4 py-12 sm:grid-cols-3">
    <!-- Docs -->
    <div>
      <h3 class="mb-3 text-sm font-semibold text-footer-foreground">Docs</h3>
      <ul class="space-y-2 text-sm text-footer-muted">
        <li>
          <a href={`${base}/docs/tailwind4/getting-started`} class="hover:text-footer-foreground"
            >Tailwind v4</a
          >
        </li>
        <li>
          <a href={`${base}/docs/tailwind3/getting-started`} class="hover:text-footer-foreground"
            >Tailwind v3</a
          >
        </li>
        <li>
          <a href={`${base}/docs/styled/getting-started`} class="hover:text-footer-foreground"
            >Styled</a
          >
        </li>
        <li>
          <a href={`${base}/docs/headless/getting-started`} class="hover:text-footer-foreground"
            >Headless</a
          >
        </li>
        <li>
          <a href={`${base}/docs/guides/accessibility`} class="hover:text-footer-foreground"
            >Guides</a
          >
        </li>
      </ul>
    </div>

    <!-- Packages -->
    <div>
      <h3 class="mb-3 text-sm font-semibold text-footer-foreground">Packages</h3>
      <ul class="space-y-2 text-sm text-footer-muted">
        <li>
          <a
            href="https://www.npmjs.com/package/react-date-range-picker-headless"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 hover:text-footer-foreground"
            >headless <svg
              class="size-3"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline
                points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg
            ></a
          >
        </li>
        <li>
          <a
            href="https://www.npmjs.com/package/react-date-range-picker-styled"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 hover:text-footer-foreground"
            >styled <svg
              class="size-3"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline
                points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg
            ></a
          >
        </li>
        <li>
          <a
            href="https://www.npmjs.com/package/react-date-range-picker-tailwind3"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 hover:text-footer-foreground"
            >tailwind3 <svg
              class="size-3"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline
                points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg
            ></a
          >
        </li>
        <li>
          <a
            href="https://www.npmjs.com/package/react-date-range-picker-tailwind4"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 hover:text-footer-foreground"
            >tailwind4 <svg
              class="size-3"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline
                points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg
            ></a
          >
        </li>
      </ul>
    </div>

    <!-- Links -->
    <div>
      <h3 class="mb-3 text-sm font-semibold text-footer-foreground">Links</h3>
      <ul class="space-y-2 text-sm text-footer-muted">
        <li>
          <a
            href="https://github.com/dsikeres1/react-date-range-picker"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 hover:text-footer-foreground"
            >GitHub <svg
              class="size-3"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline
                points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg
            ></a
          >
        </li>
      </ul>
    </div>
  </div>

  <!-- BMAC logo -->
  <div class="border-t border-footer-border px-4 py-6 text-center">
    <a href="https://www.buymeacoffee.com/dsikeres1" target="_blank" rel="noopener noreferrer">
      <img
        src={`${base}/bmc-button.png`}
        alt="Buy Me a Coffee"
        width="180"
        class="mx-auto"
        loading="lazy"
      />
    </a>
    <p class="mt-4 text-xs text-footer-muted">
      Copyright &copy; {new Date().getFullYear()} DSikeres1. All rights reserved.
    </p>
  </div>
</footer>
