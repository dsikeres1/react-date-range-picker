---
import BaseLayout from "./BaseLayout.astro";
import GNB from "@/components/GNB.astro";
import Sidebar from "@/components/Sidebar.astro";

import TOC from "@/components/TOC.astro";
import Footer from "@/components/Footer.astro";
import type { SidebarItem } from "@/lib/sidebar";
import { findPrevNext } from "@/lib/sidebar";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  section: string;
  sidebarItems: SidebarItem[];
  headings: Heading[];
  lang?: string;
}

const { title, description, section, sidebarItems, headings, lang = "en" } = Astro.props;
const currentPath = Astro.url.pathname;
const { prev, next } = findPrevNext(sidebarItems, currentPath);
---

<BaseLayout title={title} description={description} lang={lang}>
  <GNB lang={lang} />
  <div class="mx-auto flex flex-1 max-w-7xl">
    <Sidebar items={sidebarItems} section={section} />
    <main class="min-w-0 flex-1 px-6 py-8 lg:px-10">
      <article
        class="prose prose-slate dark:prose-invert max-w-none"
        data-pagefind-body
        data-pagefind-filter={`section:${section}`}
        data-pagefind-meta={`title:${title}`}
      >
        <slot />
      </article>

      <!-- Prev / Next navigation -->
      {
        (prev || next) && (
          <nav class="mt-12 flex items-stretch gap-4 border-t border-border pt-6">
            {prev ? (
              <a
                href={prev.href}
                class="group flex flex-1 flex-col rounded-lg border border-border p-4 transition-colors hover:border-primary/50"
              >
                <span class="text-xs font-medium text-muted-foreground">Previous</span>
                <span class="mt-1 text-sm font-semibold text-foreground group-hover:text-primary">
                  {prev.label}
                </span>
              </a>
            ) : (
              <div class="flex-1" />
            )}
            {next ? (
              <a
                href={next.href}
                class="group flex flex-1 flex-col items-end rounded-lg border border-border p-4 text-right transition-colors hover:border-primary/50"
              >
                <span class="text-xs font-medium text-muted-foreground">Next</span>
                <span class="mt-1 text-sm font-semibold text-foreground group-hover:text-primary">
                  {next.label}
                </span>
              </a>
            ) : (
              <div class="flex-1" />
            )}
          </nav>
        )
      }
    </main>
    <TOC headings={headings} />
  </div>
  <Footer />
</BaseLayout>
