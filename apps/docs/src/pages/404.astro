---
import BaseLayout from "@/layouts/BaseLayout.astro";
import GNB from "@/components/GNB.astro";
import Footer from "@/components/Footer.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Page Not Found">
  <GNB />
  <main class="flex min-h-[60vh] flex-col items-center justify-center px-4 py-20 text-center">
    <h1 class="text-6xl font-bold text-foreground">404</h1>
    <p class="mt-4 text-lg text-muted-foreground">Page not found</p>
    <p class="mt-2 text-sm text-muted-foreground">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a
      href={base}
      class="mt-8 inline-block rounded-lg bg-primary px-6 py-2.5 text-sm font-semibold text-primary-foreground shadow-sm hover:bg-primary/90"
    >
      Go Home
    </a>
  </main>
  <Footer />
</BaseLayout>
