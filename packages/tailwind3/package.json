{
  "name": "react-date-range-picker-tailwind3",
  "version": "0.1.3",
  "description": "Date range picker for React with Tailwind CSS v3",
  "author": "DSikeres1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dsikeres1/react-date-range-picker.git",
    "directory": "packages/tailwind3"
  },
  "bugs": {
    "url": "https://github.com/dsikeres1/react-date-range-picker/issues"
  },
  "homepage": "https://dsikeres1.github.io/react-date-range-picker/",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./rdrp-reset.css": "./rdrp-reset.css"
  },
  "license": "MIT",
  "files": [
    "dist",
    "rdrp-reset.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "react",
    "date",
    "range",
    "picker",
    "datepicker",
    "daterange",
    "calendar",
    "tailwind",
    "tailwindcss"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": "^3.2.0"
  },
  "sideEffects": [
    "*.css"
  ],
  "dependencies": {
    "@floating-ui/react": "^0.27.18",
    "clsx": "^2.1.1",
    "react-date-range-picker-headless": "workspace:*",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react-date-range-picker-ui-primitives": "workspace:*",
    "tailwindcss": "^3.4.19",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3"
  },
  "type": "commonjs"
}
