{
  "name": "react-date-range-picker-tailwind4",
  "version": "0.2.4",
  "description": "Date & range picker for React + Tailwind CSS v4 — shadcn/ui compatible, design tokens, dark mode, keyboard navigation, 15 locales",
  "author": "DSikeres1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dsikeres1/react-date-range-picker.git",
    "directory": "packages/tailwind4"
  },
  "bugs": {
    "url": "https://github.com/dsikeres1/react-date-range-picker/issues"
  },
  "homepage": "https://dsikeres1.github.io/react-date-range-picker/",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./rdrp-reset.css": "./rdrp-reset.css",
    "./rdrp-theme.css": "./rdrp-theme.css",
    "./rdrp-styles.css": "./dist/rdrp-styles.css"
  },
  "license": "MIT",
  "files": [
    "dist",
    "rdrp-reset.css",
    "rdrp-theme.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "react",
    "date-picker",
    "date-range-picker",
    "datepicker",
    "daterange",
    "calendar",
    "tailwind",
    "tailwindcss",
    "tailwind-v4",
    "shadcn",
    "shadcn-ui",
    "shadcn-registry",
    "design-tokens",
    "semantic-tokens",
    "time-picker",
    "date-time-picker",
    "compound-component",
    "keyboard-navigation",
    "accessible",
    "a11y",
    "dark-mode",
    "i18n",
    "locale",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": "^4.0.0"
  },
  "sideEffects": [
    "*.css"
  ],
  "dependencies": {
    "@floating-ui/react": "^0.27.18",
    "clsx": "^2.1.1",
    "react-date-range-picker-headless": "workspace:*",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react-date-range-picker-ui-primitives": "workspace:*",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3"
  },
  "type": "commonjs"
}
