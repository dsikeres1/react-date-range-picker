{
  "name": "react-date-range-picker-headless",
  "version": "0.2.3",
  "description": "Headless date & range picker hooks for React — zero dependencies, compound components, keyboard navigation, 15 locales",
  "author": "DSikeres1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dsikeres1/react-date-range-picker.git",
    "directory": "packages/headless"
  },
  "bugs": {
    "url": "https://github.com/dsikeres1/react-date-range-picker/issues"
  },
  "homepage": "https://dsikeres1.github.io/react-date-range-picker/",
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "react",
    "date-picker",
    "date-range-picker",
    "datepicker",
    "daterange",
    "calendar",
    "headless",
    "hooks",
    "unstyled",
    "composable",
    "compound-component",
    "time-picker",
    "date-time-picker",
    "keyboard-navigation",
    "accessible",
    "a11y",
    "i18n",
    "locale",
    "dark-mode",
    "typescript",
    "zero-dependency"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
